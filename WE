module rssi_gain_calibration_advanced(

    input clk,
    input rst,

    output reg [12:0] lo_freq_mhz,
    output reg [5:0]  gain_index,
    output reg done
);

    parameter LO_START = 4000;
    parameter LO_END   = 6000;
    parameter LO_STEP  = 100;

    parameter TARGET_RSSI = 1000;
    parameter THRESHOLD   = 15;
    parameter TIMEOUT_MAX = 200;

    reg [15:0] rssi_raw;
    wire [15:0] rssi_avg;

    reg [15:0] timeout_counter;

    reg [2:0] state;

    localparam SET_LO=0, MEASURE=1, ADJUST=2, STORE=3, NEXT=4, FINISH=5;

    // RSSI model (reuse earlier model)
    rssi_model model(
        .lo_freq_mhz(lo_freq_mhz),
        .gain_index(gain_index),
        .rssi_out(rssi_raw)
    );

    // Filter
    rssi_filter filt(
        .clk(clk),
        .rst(rst),
        .rssi_in(rssi_raw),
        .rssi_avg(rssi_avg)
    );

    // Calibration storage (LUT for each 100 MHz step)
    reg [5:0] calibration_lut [0:20];  // 4000–6000 in 100 MHz = 21 steps
    reg [4:0] freq_index;

    always @(posedge clk or posedge rst) begin
        if (rst) begin
            lo_freq_mhz <= LO_START;
            gain_index <= 0;
            freq_index <= 0;
            timeout_counter <= 0;
            done <= 0;
            state <= SET_LO;
        end else begin

            case(state)

                SET_LO: begin
                    gain_index <= 0;
                    timeout_counter <= 0;
                    state <= MEASURE;
                end

                MEASURE: begin
                    timeout_counter <= timeout_counter + 1;
                    state <= ADJUST;
                end

                ADJUST: begin

                    if (timeout_counter > TIMEOUT_MAX) begin
                        state <= STORE;  // Timeout protection
                    end
                    else if ( (rssi_avg > TARGET_RSSI-THRESHOLD) &&
                              (rssi_avg < TARGET_RSSI+THRESHOLD)) begin
                        state <= STORE;
                    end
                    else if (rssi_avg < TARGET_RSSI) begin
                        gain_index <= gain_index + 1;
                        state <= MEASURE;
                    end
                    else begin
                        gain_index <= gain_index - 1;
                        state <= MEASURE;
                    end
                end

                STORE: begin
                    calibration_lut[freq_index] <= gain_index;
                    state <= NEXT;
                end

                NEXT: begin
                    if (lo_freq_mhz < LO_END) begin
                        lo_freq_mhz <= lo_freq_mhz + LO_STEP;
                        freq_index <= freq_index + 1;
                        state <= SET_LO;
                    end else begin
                        state <= FINISH;
                    end
                end

                FINISH: done <= 1;

            endcase
        end
    end

endmodule

`timescale 1ns/1ps

module tb_rssi_gain_calibration_advanced;

    reg clk = 0;
    reg rst = 1;

    wire [12:0] lo_freq_mhz;
    wire [5:0]  gain_index;
    wire done;

    integer i;

    // DUT
    rssi_gain_calibration_advanced DUT (
        .clk(clk),
        .rst(rst),
        .lo_freq_mhz(lo_freq_mhz),
        .gain_index(gain_index),
        .done(done)
    );

    // Clock generation (100 MHz equivalent timing)
    always #5 clk = ~clk;

    // Reset sequence
    initial begin
        $dumpfile("rssi_calibration_advanced.vcd");
        $dumpvars(0, tb_rssi_gain_calibration_advanced);

        #20 rst = 0;
    end

    // Monitor live sweep activity
    initial begin
        $display("-----------------------------------------------------");
        $display("   AD9361 RSSI Gain Step Calibration Simulation");
        $display("   LO Range: 4000 MHz to 6000 MHz (100 MHz step)");
        $display("-----------------------------------------------------");

        $monitor("Time=%0t | LO=%0d MHz | GainIndex=%0d | State=%0d | RSSI_Avg=%0d",
                 $time,
                 DUT.lo_freq_mhz,
                 DUT.gain_index,
                 DUT.state,
                 DUT.rssi_avg);
    end

    // Wait for calibration to complete
    initial begin
        wait(done);

        $display("\n==============================================");
        $display("     CALIBRATION COMPLETE");
        $display("==============================================");

        $display("\nFinal Calibration LUT (LO vs Gain Index):");

        for (i = 0; i <= 20; i = i + 1) begin
            $display("LO = %0d MHz  -> Gain Index = %0d",
                     4000 + (i*100),
                     DUT.calibration_lut[i]);
        end

        $display("\nSimulation Finished Successfully.");
        #50;
        $finish;
    end

endmodule



clc;
clear;
close all;

%% PARAMETERS

LO_START = 4000;      % MHz
LO_END   = 6000;      % MHz
LO_STEP  = 100;       % MHz

GAIN_MIN = 0;
GAIN_MAX = 63;

TARGET_RSSI = 1000;
THRESHOLD   = 15;

TIMEOUT_MAX = 200;    % Max iterations per frequency
AVG_SAMPLES = 4;      % Moving average window

lo_range = LO_START:LO_STEP:LO_END;
num_freq = length(lo_range);

calibration_lut = zeros(1, num_freq);

%% SIMULATION STORAGE

all_gain_history = {};
all_rssi_history = {};

%% MAIN CALIBRATION LOOP

for f_idx = 1:num_freq

    lo_freq = lo_range(f_idx);
    gain_index = GAIN_MIN;
    
    timeout_counter = 0;
    rssi_buffer = zeros(1, AVG_SAMPLES);
    
    gain_history = [];
    rssi_history = [];
    
    while true
        
        timeout_counter = timeout_counter + 1;
        
        %% RSSI MODEL (Frequency dependent + Gain dependent)
        % RSSI increases with gain
        % Slight variation with frequency
        rssi_raw = (gain_index * 20) + ...
                   ((lo_freq - 4000)/10) + ...
                   200 + randn*5;  % Add small noise
        
        %% Moving Average Filter
        rssi_buffer = [rssi_buffer(2:end), rssi_raw];
        rssi_avg = mean(rssi_buffer);
        
        gain_history(end+1) = gain_index;
        rssi_history(end+1) = rssi_avg;
        
        %% Convergence Check
        if abs(rssi_avg - TARGET_RSSI) <= THRESHOLD
            break;
        end
        
        %% Timeout Protection
        if timeout_counter > TIMEOUT_MAX
            disp(['Timeout at LO = ', num2str(lo_freq), ' MHz']);
            break;
        end
        
        %% Gain Adjustment Logic
        if rssi_avg < TARGET_RSSI
            gain_index = min(gain_index + 1, GAIN_MAX);
        else
            gain_index = max(gain_index - 1, GAIN_MIN);
        end
        
    end
    
    calibration_lut(f_idx) = gain_index;
    
    all_gain_history{f_idx} = gain_history;
    all_rssi_history{f_idx} = rssi_history;
    
end

%% DISPLAY RESULTS

disp('==========================================');
disp('Calibration Complete');
disp('==========================================');

for i = 1:num_freq
    fprintf('LO = %d MHz -> Gain Index = %d\n', ...
        lo_range(i), calibration_lut(i));
end

%% VISUALIZATION

figure;
plot(lo_range, calibration_lut, '-o');
xlabel('LO Frequency (MHz)');
ylabel('Calibrated Gain Index');
title('Calibration LUT vs LO Frequency');
grid on;

%% Detailed Visualization for Few Frequencies

figure;
hold on;
for k = 1:3
    plot(all_gain_history{k}, all_rssi_history{k});
end
xlabel('Gain Step Iteration');
ylabel('RSSI (Averaged)');
title('RSSI Convergence for First 3 LO Steps');
legend('4000 MHz','4100 MHz','4200 MHz');
grid on;
