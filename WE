module rssi_gain_calibration(

    input clk,
    input rst,

    output reg [12:0] lo_freq_mhz,
    output reg [5:0]  gain_index,
    output reg done

);

    parameter LO_START = 13'd4000;
    parameter LO_END   = 13'd6000;
    parameter LO_STEP  = 13'd100;

    parameter TARGET_RSSI = 16'd1000;
    parameter THRESHOLD   = 16'd10;

    reg [15:0] rssi_value;
    wire [15:0] rssi_wire;

    reg [2:0] state;

    localparam IDLE      = 0,
               SET_LO    = 1,
               MEASURE   = 2,
               ADJUST    = 3,
               NEXT_LO   = 4,
               FINISH    = 5;

    // Instantiate RSSI model
    rssi_model model(
        .lo_freq_mhz(lo_freq_mhz),
        .gain_index(gain_index),
        .rssi_out(rssi_wire)
    );

    always @(posedge clk or posedge rst) begin
        if (rst) begin
            state <= IDLE;
            lo_freq_mhz <= LO_START;
            gain_index <= 0;
            done <= 0;
        end else begin

            case (state)

                IDLE: begin
                    lo_freq_mhz <= LO_START;
                    gain_index <= 0;
                    done <= 0;
                    state <= SET_LO;
                end

                SET_LO: begin
                    gain_index <= 0;
                    state <= MEASURE;
                end

                MEASURE: begin
                    rssi_value <= rssi_wire;
                    state <= ADJUST;
                end

                ADJUST: begin
                    if ( (rssi_value > TARGET_RSSI - THRESHOLD) &&
                         (rssi_value < TARGET_RSSI + THRESHOLD) ) begin
                        state <= NEXT_LO;
                    end
                    else if (rssi_value < TARGET_RSSI) begin
                        gain_index <= gain_index + 1;
                        state <= MEASURE;
                    end
                    else begin
                        gain_index <= gain_index - 1;
                        state <= MEASURE;
                    end
                end

                NEXT_LO: begin
                    if (lo_freq_mhz < LO_END) begin
                        lo_freq_mhz <= lo_freq_mhz + LO_STEP;
                        state <= SET_LO;
                    end
                    else begin
                        state <= FINISH;
                    end
                end

                FINISH: begin
                    done <= 1;
                end

            endcase
        end
    end

endmodule


