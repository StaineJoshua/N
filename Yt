// ============================================================
// CALIBRATION FSM
// ============================================================

module rssi_gain_calibration(
    input clk,
    input rst,
    input start_cal,
    input [15:0] lo_freq_mhz,

    output spi_start,
    output spi_rw,
    output [15:0] spi_addr,
    output [7:0] spi_wdata,
    input [7:0] spi_rdata,
    input spi_done,

    output reg cal_done
);

parameter LO_MIN = 4000;
parameter LO_MAX = 6000;
parameter GAIN_MAX = 76;
parameter RSSI_TARGET = 1200;

reg [3:0] state;
reg [7:0] gain_index;
reg [15:0] rssi_value;
reg [15:0] error_val;

localparam IDLE=0, SET_GAIN=1, SET_LNA=2,
           READ_MSB=3, READ_LSB=4,
           COMPUTE=5, NEXT_GAIN=6, DONE=7;

assign spi_start = (state==SET_GAIN) ||
                   (state==SET_LNA) ||
                   (state==READ_MSB) ||
                   (state==READ_LSB);

assign spi_rw = (state==READ_MSB || state==READ_LSB);

assign spi_addr =
    (state==SET_GAIN) ? 16'h0109 :
    (state==SET_LNA)  ? 16'h0113 :
    (state==READ_MSB) ? 16'h01A7 :
    (state==READ_LSB) ? 16'h01A8 :
                        16'h0000;

assign spi_wdata =
    (state==SET_GAIN) ? gain_index :
    (state==SET_LNA)  ? 8'h01 : 8'h00;

reg [15:0] cal_lut [0:GAIN_MAX];

always @(posedge clk or posedge rst)
begin
    if (rst)
    begin
        state <= IDLE;
        gain_index <= 0;
        cal_done <= 0;
    end
    else
    begin
        case(state)

        IDLE:
        begin
            cal_done <= 0;
            if (start_cal &&
                lo_freq_mhz >= LO_MIN &&
                lo_freq_mhz <= LO_MAX)
            begin
                gain_index <= 0;
                state <= SET_GAIN;
            end
        end

        SET_GAIN:
            if (spi_done) state <= SET_LNA;

        SET_LNA:
            if (spi_done) state <= READ_MSB;

        READ_MSB:
            if (spi_done)
            begin
                rssi_value[15:8] <= spi_rdata;
                state <= READ_LSB;
            end

        READ_LSB:
            if (spi_done)
            begin
                rssi_value[7:0] <= spi_rdata;
                state <= COMPUTE;
            end

        COMPUTE:
        begin
            if (rssi_value > RSSI_TARGET)
                error_val <= rssi_value - RSSI_TARGET;
            else
                error_val <= RSSI_TARGET - rssi_value;

            cal_lut[gain_index] <= error_val;
            state <= NEXT_GAIN;
        end

        NEXT_GAIN:
        begin
            if (gain_index < GAIN_MAX)
            begin
                gain_index <= gain_index + 1;
                state <= SET_GAIN;
            end
            else
                state <= DONE;
        end

        DONE:
        begin
            cal_done <= 1;
            state <= IDLE;
        end

        endcase
    end
end

endmodule


// ============================================================
// SIMPLE AD9361 BEHAVIORAL MODEL
// ============================================================

module ad9361_model(
    input clk,
    input spi_start,
    input spi_rw,
    input [15:0] spi_addr,
    input [7:0] spi_wdata,
    output reg [7:0] spi_rdata,
    output reg spi_done
);

reg [7:0] gain_index = 0;
reg [15:0] fake_rssi;

always @(posedge clk)
begin
    spi_done <= 0;

    if (spi_start)
    begin
        spi_done <= 1;

        if (!spi_rw)
        begin
            if (spi_addr == 16'h0109)
                gain_index <= spi_wdata;
        end
        else
        begin
            // RSSI model:
            // RSSI = 800 + gain_index * 10
            fake_rssi = 800 + gain_index * 10;

            if (spi_addr == 16'h01A7)
                spi_rdata <= fake_rssi[15:8];
            else if (spi_addr == 16'h01A8)
                spi_rdata <= fake_rssi[7:0];
        end
    end
end

endmodule

gain_index → 0.5 dB step
LNA ON → +15 dB
LO variation → ±2 dB across 4–6 GHz
Noise → ±1 dB random


RSSI_code = (InputPower + TotalGain + 100) × 10


