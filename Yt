`timescale 1ns/1ps

module rssi_gain_calibration(
    input              clk,
    input              rst,
    input              start_cal,
    input      [15:0]  lo_freq_mhz,

    // SPI interface
    output reg         spi_start,
    output reg         spi_rw,
    output reg [15:0]  spi_addr,
    output reg [7:0]   spi_wdata,
    input      [7:0]   spi_rdata,
    input              spi_done,

    output reg         cal_done
);

parameter LO_MIN       = 4000;
parameter LO_MAX       = 6000;
parameter GAIN_MAX     = 76;
parameter TARGET_DBM   = -20;

localparam IDLE      = 3'd0,
           SET_GAIN  = 3'd1,
           SET_LNA   = 3'd2,
           READ_MSB  = 3'd3,
           READ_LSB  = 3'd4,
           COMPUTE   = 3'd5,
           NEXT_GAIN = 3'd6,
           DONE      = 3'd7;

reg [2:0] state;
reg [7:0] gain_index;
reg [15:0] rssi_value;
reg signed [15:0] measured_dbm;
reg signed [15:0] error_val;

// Calibration LUT
reg signed [15:0] cal_lut [0:GAIN_MAX];

always @(posedge clk or posedge rst)
begin
    if (rst)
    begin
        state       <= IDLE;
        gain_index  <= 0;
        cal_done    <= 0;
        spi_start   <= 0;
    end
    else
    begin
        spi_start <= 0;

        case(state)

        IDLE:
        begin
            cal_done <= 0;
            if (start_cal &&
                lo_freq_mhz >= LO_MIN &&
                lo_freq_mhz <= LO_MAX)
            begin
                gain_index <= 0;
                state <= SET_GAIN;
            end
        end

        SET_GAIN:
        begin
            spi_start <= 1;
            spi_rw    <= 0;
            spi_addr  <= 16'h0109;
            spi_wdata <= gain_index;
            if (spi_done)
                state <= SET_LNA;
        end

        SET_LNA:
        begin
            spi_start <= 1;
            spi_rw    <= 0;
            spi_addr  <= 16'h0113;
            spi_wdata <= 8'h01;  // LNA ON
            if (spi_done)
                state <= READ_MSB;
        end

        READ_MSB:
        begin
            spi_start <= 1;
            spi_rw    <= 1;
            spi_addr  <= 16'h01A7;
            if (spi_done)
            begin
                rssi_value[15:8] <= spi_rdata;
                state <= READ_LSB;
            end
        end

        READ_LSB:
        begin
            spi_start <= 1;
            spi_rw    <= 1;
            spi_addr  <= 16'h01A8;
            if (spi_done)
            begin
                rssi_value[7:0] <= spi_rdata;
                state <= COMPUTE;
            end
        end

        COMPUTE:
        begin
            // Reverse RSSI mapping
            measured_dbm <= (rssi_value / 10) - 100;
            error_val    <= measured_dbm - TARGET_DBM;

            cal_lut[gain_index] <= error_val;
            state <= NEXT_GAIN;
        end

        NEXT_GAIN:
        begin
            if (gain_index < GAIN_MAX)
            begin
                gain_index <= gain_index + 1;
                state <= SET_GAIN;
            end
            else
                state <= DONE;
        end

        DONE:
        begin
            cal_done <= 1;
            state <= IDLE;
        end

        endcase
    end
end

endmodule



