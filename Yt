    .spi_addr(spi_addr),
    .spi_wdata(spi_wdata),
    .spi_rdata(spi_rdata),
    .spi_done(spi_done),
    .cal_done(cal_done)
);

// -------------------------------------------------
// AD9361 REALISTIC MODEL
// -------------------------------------------------

reg [7:0] gain_index = 0;
reg lna_on = 0;
reg [7:0] spi_rdata_reg;
reg spi_done_reg;

assign spi_rdata = spi_rdata_reg;
assign spi_done  = spi_done_reg;

integer input_power;
integer total_gain_db;
integer lo_variation;
integer noise;
integer output_dbm;
integer fake_rssi;

always @(posedge clk)
begin
    spi_done_reg <= 0;

    if (spi_start)
    begin
        spi_done_reg <= 1;

        if (!spi_rw)
        begin
            if (spi_addr == 16'h0109)
                gain_index <= spi_wdata;

            if (spi_addr == 16'h0113)
                lna_on <= spi_wdata[0];
        end
        else
        begin
            input_power = -60;
            total_gain_db = gain_index / 2;

            if (lna_on)
                total_gain_db = total_gain_db + 15;

            lo_variation = (lo_freq - 5000) / 500;
            noise = $random % 2;

            output_dbm = input_power
                       + total_gain_db
                       + lo_variation
                       + noise;

            fake_rssi = (output_dbm + 100) * 10;

            if (spi_addr == 16'h01A7)
                spi_rdata_reg <= fake_rssi[15:8];
            else if (spi_addr == 16'h01A8)
                spi_rdata_reg <= fake_rssi[7:0];
        end
    end
end

